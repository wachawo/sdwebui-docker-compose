# Build target
# Default: Dockerfile (CUDA 13.0 + torch cu130) — for driver reporting CUDA >= 13.
# Alt:     Dockerfile.cu124 (CUDA 12.4 + torch cu124) — for driver 12.4.
DOCKERFILE=Dockerfile
SDWEBUI_IMAGE=sdwebui_gpu

TZ=America/New_York

SDWEBUI_HOST=0.0.0.0
SDWEBUI_PORT=7860

# Extra flags passed to launch.py (e.g. "--medvram", "--lowvram", "--no-half",
# "--enable-insecure-extension-access").
# Note on --xformers: sdwebui's launch.py installs xformers==0.0.23.post1 by
# default, which is built for torch 2.1.2+cu121 and mismatches our torch
# 2.6.0+cu124 / 2.10+cu130. Use XFORMERS_PACKAGE below to pin a matching
# version if you need it. Torch 2.x SDPA (used by default) is comparable.
SDWEBUI_EXTRA_ARGS=

NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Sub-repo URL overrides for launch.py's prepare_environment().
# The upstream Stability-AI/stablediffusion repo was deleted in late 2025 — we
# default to w-e-w's fork (sdwebui contributor; also used by sdwebui's dev
# branch). Leave the rest at upstream unless a similar breakage appears.
STABLE_DIFFUSION_REPO=https://github.com/w-e-w/stablediffusion.git
STABLE_DIFFUSION_XL_REPO=https://github.com/Stability-AI/generative-models.git
K_DIFFUSION_REPO=https://github.com/crowsonkb/k-diffusion.git
BLIP_REPO=https://github.com/salesforce/BLIP.git

# xformers package spec used when --xformers is in SDWEBUI_EXTRA_ARGS.
# `xformers` (unpinned) → pip installs the latest PyPI wheel, which targets
# recent torch. sdwebui's own default `xformers==0.0.23.post1` is built for
# torch 2.1.2+cu121 and mismatches our torch 2.6+/2.10+, causing import
# warnings at runtime.
XFORMERS_PACKAGE=xformers

# Model download tokens
# Civitai:     https://civitai.com/user/account  →  API Keys
# HuggingFace: https://huggingface.co/settings/tokens
CIVITAI_TOKEN=
HF_TOKEN=

# HuggingFace Hub behavior
# HF_HUB_OFFLINE=1 disables network — use when all models are already cached.
HF_HUB_OFFLINE=0
HUGGINGFACE_HUB_CACHE=/opt/stable-diffusion-webui/cache
